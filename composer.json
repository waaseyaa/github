{
    "name": "waaseyaa/github",
    "description": "GitHub API client for issues, milestones, and pull requests",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\GitHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\GitHub\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "layer": 6
        }
    },
    "config": {
        "sort-packages": true
    }
}
